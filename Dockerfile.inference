FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY crypto_pqc.py .
COPY predictive_inference/ predictive_inference/

EXPOSE 8003

ENV PYTHONPATH=/app

CMD ["uvicorn", "predictive_inference.inference_service:app", "--host", "0.0.0.0", "--port", "8003"]
