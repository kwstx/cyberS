FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN apt-get update && apt-get install -y gcc g++ libgomp1 && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir -r requirements.txt

COPY crypto_pqc.py .
COPY core/ core/
COPY predictive_inference/ predictive_inference/

EXPOSE 8003

ENV PYTHONPATH=/app

CMD ["uvicorn", "predictive_inference.inference_service:app", "--host", "0.0.0.0", "--port", "8003"]
