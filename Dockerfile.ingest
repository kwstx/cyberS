FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY crypto_pqc.py .
COPY data_ingestion/ data_ingestion/

EXPOSE 8000

ENV PYTHONPATH=/app

CMD ["uvicorn", "data_ingestion.ingestion_service:app", "--host", "0.0.0.0", "--port", "8000"]
